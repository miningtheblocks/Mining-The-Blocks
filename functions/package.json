{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "lint": "eslint .",
    "test": "jest --testPathIgnorePatterns=rules.test.js",
    "test:rules": "firebase emulators:exec --only firestore --project demo-mtb \"jest --testRegex=rules.test.js\"",
    "test:all": "npm run lint && npm run test",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "ethers": "^6.16.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-security": "^4.0.1",
    "firebase-functions-test": "^3.5.0",
    "jest": "^30.4.2"
  },
  "private": true
}
