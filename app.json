{
  "expo": {
    "name": "mining the blocks",
    "slug": "miningtheblocks",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bissi.miningtheblocks"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a0a0a",
          "androidMode": "default",
          "androidCollapsedTitle": "Mining The Blocks"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4718826806092770~3631324090"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "07696d8f-1768-40e0-88fa-4e410fc48eb6"
      }
    },
    "owner": "miningtheblock"
  }
}
